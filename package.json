{
    "name": "@fooxit/tab-data",
    "version": "1.0.0",
    "type": "module",
    "files": [
        "dist"
    ],
    "main": "./dist/tab-data.umd.cjs",
    "module": "./dist/tab-data.js",
    "exports": {
        ".": {
            "import": "./dist/tab-data.js",
            "require": "./dist/my-lib.umd.cjs"
        }
    },
    "scripts": {
        "dev": "vite",
